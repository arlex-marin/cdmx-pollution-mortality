# =============================================================================
# .gitignore - Project 1: Air Pollution and Cancer Mortality in CDMX
# =============================================================================

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.dylib
*.dll
.python-version

# Jupyter Notebook
.ipynb_checkpoints/
*.ipynb

# Virtual environments
venv/
env/
.venv/
env.bak/

# IDE directories
.idea/
.vscode/
*.swp
*.swo
*.swn

# OS-specific files
.DS_Store
Thumbs.db
desktop.ini
*.lnk

# Data directories (immutable raw data)
data/raw/
data/processed/
data/external/

# Logs (execution logs only)
logs/*.log
logs/*.json

# Temporary files
*.tmp
*.temp
*.bak
*.cache

# Coverage
.coverage
.coverage_html
.coverage.json
.coverage.xml
.pytest_cache/

# Build artifacts
dist/
build/
*.egg-info/
*.dist-info/
__pycache__/

# Outputs (generated by pipeline - uncomment if not tracking)
# outputs/figures/
# outputs/tables/
# outputs/models/

# Environment files
.env
.env.local
.env.*
*.code-workspace

# Archives and compressed files
*.zip
*.tar
*.gz
*.bz2
*.7z
*.rar

# Database files
*.db
*.sqlite
*.sqlite3
*.mdb
*.accdb
*.mdf
*.ndf
*.ldf

# Docker
.docker/
Dockerfile
docker-compose.yml
docker-compose.override.yml

# Project management
.project
.pmp
.mpp
.mpt
.mpx
.prj
